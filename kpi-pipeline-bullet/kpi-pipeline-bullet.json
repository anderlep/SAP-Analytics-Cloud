{
  "id": "com.company.sac.kpi.pipeline.bullet",
  "version": "1.8.2",
  "name": "KPI Pipeline Bullet",
  "description": "Custom KPI pipeline bullet chart with dynamic zones, configurable styling, semantic rules, adaptive layout and script-driven dimension breakdown via manually built JSON items/result sets.",
  "newInstancePrefix": "KpiPipelineBullet",
  "vendor": "petr.anderle@mathematix.cz",
  "license": "",
  "eula": "",
  "icon": "https://anderlep.github.io/SAP-Analytics-Cloud/kpi-pipeline-bullet/icon.png",
  "supportsMobile": true,
  "supportsExport": true,
  "webcomponents": [
    {
      "kind": "main",
      "tag": "kpi-pipeline-bullet",
      "url": "https://anderlep.github.io/SAP-Analytics-Cloud/kpi-pipeline-bullet/kpi-pipeline-bullet.js",
      "integrity": "",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
    "actualValue": {
      "type": "number",
      "default": 450
    },
    "referenceValue": {
      "type": "number",
      "default": 500
    },
    "lowerBoundZonePercentage": {
      "type": "number",
      "default": 40
    },
    "targetZonePercentage": {
      "type": "number",
      "default": 20
    },
    "upperBoundZonePercentage": {
      "type": "number",
      "default": 40
    },
    "lowerBoundZoneColor": {
      "type": "string",
      "default": "#E74C3C"
    },
    "targetZoneColor": {
      "type": "string",
      "default": "#2ECC71"
    },
    "upperBoundZoneColor": {
      "type": "string",
      "default": "#F1C40F"
    },
    "markerColor": {
      "type": "string",
      "default": "#2F3C7E"
    },
    "referenceLineColor": {
      "type": "string",
      "default": "#111111"
    },
    "varianceColor": {
      "type": "string",
      "default": "#5E6978"
    },
    "showLabels": {
      "type": "boolean",
      "default": true
    },
    "showMarkerLabel": {
      "type": "boolean",
      "default": true
    },
    "showAxisLabels": {
      "type": "boolean",
      "default": false
    },
    "showReferenceLine": {
      "type": "boolean",
      "default": false
    },
    "referenceLineOnHover": {
      "type": "boolean",
      "default": true
    },
    "showVarianceIndicator": {
      "type": "boolean",
      "default": false
    },
    "varianceOnHover": {
      "type": "boolean",
      "default": true
    },
    "varianceLineStyle": {
      "type": "string",
      "default": "dashed"
    },
    "varianceDisplayMode": {
      "type": "string",
      "default": "both"
    },
    "varianceSeparator": {
      "type": "string",
      "default": " | "
    },
    "showTooltip": {
      "type": "boolean",
      "default": true
    },
    "barHeight": {
      "type": "number",
      "default": 18
    },
    "markerWidth": {
      "type": "number",
      "default": 3
    },
    "markerRadius": {
      "type": "number",
      "default": 4
    },
    "referenceLineWidth": {
      "type": "number",
      "default": 2
    },
    "varianceLineWidth": {
      "type": "number",
      "default": 1.2
    },
    "fontFamily": {
      "type": "string",
      "default": "\"72\", Arial, Helvetica, sans-serif"
    },
    "fontSize": {
      "type": "number",
      "default": 12
    },
    "fontWeight": {
      "type": "string",
      "default": "normal"
    },
    "fontStyle": {
      "type": "string",
      "default": "normal"
    },
    "textColor": {
      "type": "string",
      "default": "#32363a"
    },
    "axisFontSize": {
      "type": "number",
      "default": 11
    },
    "markerFontSize": {
      "type": "number",
      "default": 13
    },
    "responsiveScaling": {
      "type": "boolean",
      "default": false
    },
    "adaptiveLayout": {
      "type": "boolean",
      "default": true
    },
    "compactHeightThreshold": {
      "type": "number",
      "default": 95
    },
    "minimalHeightThreshold": {
      "type": "number",
      "default": 70
    },
    "hideVarianceWhenCompact": {
      "type": "boolean",
      "default": true
    },
    "hideReferenceLineWhenCompact": {
      "type": "boolean",
      "default": true
    },
    "hideMarkerLabelWhenMinimal": {
      "type": "boolean",
      "default": true
    },
    "paddingTop": {
      "type": "number",
      "default": 34
    },
    "paddingLeft": {
      "type": "number",
      "default": 28
    },
    "paddingRight": {
      "type": "number",
      "default": 28
    },
    "paddingBottom": {
      "type": "number",
      "default": 24
    },
    "semanticRules": {
      "type": "string",
      "default": "[]"
    },
    "semanticIconVisible": {
      "type": "boolean",
      "default": true
    },
    "semanticIconPosition": {
      "type": "string",
      "default": "before"
    },
    "rawDecimals": {
      "type": "number",
      "default": 0
    },
    "percentDecimals": {
      "type": "number",
      "default": 1
    },
    "unit": {
      "type": "string",
      "default": ""
    },
    "clampMarker": {
      "type": "boolean",
      "default": true
    },
    "semanticIconInTooltip": {
      "type": "boolean",
      "default": true
    },
    "semanticIconInMarkerLabel": {
      "type": "boolean",
      "default": false
    },
    "showSemanticStatusInTooltip": {
      "type": "boolean",
      "default": false
    },
    "dimensionBreakdownEnabled": {
      "type": "boolean",
      "default": false
    },
    "maxBreakdownItems": {
      "type": "number",
      "default": 50
    },
    "breakdownItemHeight": {
      "type": "number",
      "default": 78
    },
    "breakdownItemGap": {
      "type": "number",
      "default": 8
    },
    "showDimensionLabel": {
      "type": "boolean",
      "default": true
    },
    "dimensionLabelPosition": {
      "type": "string",
      "default": "top"
    },
    "dimensionId": {
      "type": "string",
      "default": ""
    },
    "actualMeasureId": {
      "type": "string",
      "default": ""
    },
    "referenceMeasureId": {
      "type": "string",
      "default": ""
    },
    "breakdownItems": {
      "type": "string",
      "default": "[]"
    }
  },
  "methods": {
    "setData": {
      "description": "Set actual and reference values.",
      "parameters": [
        {
          "name": "actualValue",
          "type": "number"
        },
        {
          "name": "referenceValue",
          "type": "number"
        }
      ],
      "returnType": "void"
    },
    "setZones": {
      "description": "Set lower, target and upper zone percentages. Sum must be 100.",
      "parameters": [
        {
          "name": "lowerBoundZonePercentage",
          "type": "number"
        },
        {
          "name": "targetZonePercentage",
          "type": "number"
        },
        {
          "name": "upperBoundZonePercentage",
          "type": "number"
        }
      ],
      "returnType": "void"
    },
    "setColors": {
      "description": "Set zone colors and optionally marker color.",
      "parameters": [
        {
          "name": "lowerBoundZoneColor",
          "type": "string"
        },
        {
          "name": "targetZoneColor",
          "type": "string"
        },
        {
          "name": "upperBoundZoneColor",
          "type": "string"
        },
        {
          "name": "markerColor",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "setVarianceDisplayMode": {
      "description": "Set variance display mode.",
      "parameters": [
        {
          "name": "mode",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "setConfig": {
      "description": "Set multiple properties via JSON config.",
      "parameters": [
        {
          "name": "config",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "setDimensionBreakdownEnabled": {
      "description": "Enable or disable rendering of multiple bullet charts from breakdown items.",
      "parameters": [
        {
          "name": "enabled",
          "type": "boolean"
        }
      ],
      "returnType": "void"
    },
    "setDimensionBinding": {
      "description": "Set optional dimension and measure ids for result set parsing.",
      "parameters": [
        {
          "name": "dimensionId",
          "type": "string"
        },
        {
          "name": "actualMeasureId",
          "type": "string"
        },
        {
          "name": "referenceMeasureId",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "clearItems": {
      "description": "Clear current breakdown items.",
      "parameters": [],
      "returnType": "void"
    },
    "addItem": {
      "description": "Add one breakdown item using primitive SAC scripting values.",
      "parameters": [
        {
          "name": "id",
          "type": "string"
        },
        {
          "name": "label",
          "type": "string"
        },
        {
          "name": "actualValue",
          "type": "number"
        },
        {
          "name": "referenceValue",
          "type": "number"
        }
      ],
      "returnType": "void"
    },
    "renderItems": {
      "description": "Render previously added breakdown items.",
      "parameters": [],
      "returnType": "void"
    },
    "setItems": {
      "description": "Set breakdown items from a manually constructed JSON string.",
      "parameters": [
        {
          "name": "itemsJson",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "setRows": {
      "description": "Alias for setItems, useful when reusing Appendix Table style helpers.",
      "parameters": [
        {
          "name": "rowsJson",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "setDataJson": {
      "description": "Set either single bullet data or breakdown items from a JSON string.",
      "parameters": [
        {
          "name": "dataJson",
          "type": "string"
        }
      ],
      "returnType": "void"
    },
    "setResultSet": {
      "description": "Set data from a manually serialized SAC result set JSON string and optional mapping JSON string.",
      "parameters": [
        {
          "name": "resultSetJson",
          "type": "string"
        },
        {
          "name": "mappingJson",
          "type": "string"
        }
      ],
      "returnType": "void"
    }
  },
  "events": {}
}