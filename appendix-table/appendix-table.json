  "id": "com.company.sac.appendix.table",
  "version": "1.1.0",
  "name": "Appendix Table",
  "newInstancePrefix": "AppendixTable",
  "description": "Displays SAC variables, filters or arbitrary metadata as a configurable appendix table.",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "com-company-sac-appendix-table",
