      "integrity": "",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
    "rows": {
      "type": "string",
      "description": "JSON array with table rows."
    },
    "config": {
      "type": "string",
      "description": "JSON config object."
    },
    "columns": {
      "type": "string",
      "description": "JSON array with dynamic column definitions."
    }
  },
  "methods": {
    "setRows": {
      "description": "Sets table rows as JSON string.",
      "parameters": [
        {
          "name": "rows",
          "type": "string",
          "description": "JSON array of rows."
        }
      ],
      "returnType": "void"
    },
    "setConfig": {
      "description": "Sets table config as JSON string.",
      "parameters": [
        {
          "name": "config",
          "type": "string",
          "description": "JSON config object."
        }
      ],
      "returnType": "void"
    },
    "setColumns": {
      "description": "Sets dynamic columns as JSON string.",
      "parameters": [
        {
          "name": "columns",
          "type": "string",
          "description": "JSON array of column definitions."
        }
      ],
      "returnType": "void"
