{
  "eula": "",
  "vendor": "petr.anderle@mathematix.cz",
  "license": "",
  "id": "com.company.sac.appendix.table",
  "version": "1.2.0",
  "name": "Appendix Table",
  "newInstancePrefix": "AppendixTable",
  "description": "Displays SAC variables, filters or arbitrary metadata as a configurable and styleable appendix table.",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "com-company-sac-appendix-table",
      "url": "https://anderlep.github.io/SAP-Analytics-Cloud/appendix-table/appendix-table.js",
      "integrity": "",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
    "rows": {
      "type": "string",
      "description": "JSON array with table rows. Each row is an object."
    },
    "config": {
      "type": "string",
      "description": "JSON config object, e.g. {\"label\":\"Filter\",\"op\":\"Operator\",\"value\":\"Value\",\"showOperator\":true}."
    },
    "columns": {
      "type": "string",
      "description": "JSON array with dynamic column definitions."
    },
    "styleConfig": {
      "type": "string",
      "description": "JSON style configuration for table appearance."
    },
    "customCss": {
      "type": "string",
      "description": "Custom CSS injected into the widget shadow DOM."
    }
  },
  "methods": {
    "setRows": {
      "description": "Sets table rows as JSON string.",
      "parameters": [
        {
          "name": "rows",
          "type": "string",
          "description": "JSON array of row objects."
        }
      ],
      "returnType": "void"
    },
    "setConfig": {
      "description": "Sets table config as JSON string.",
      "parameters": [
        {
          "name": "config",
          "type": "string",
          "description": "JSON config object."
        }
      ],
      "returnType": "void"
    },
    "setColumns": {
      "description": "Sets dynamic columns as JSON string.",
      "parameters": [
        {
          "name": "columns",
          "type": "string",
          "description": "JSON array of column definitions."
        }
      ],
      "returnType": "void"
    },
    "setStyleConfig": {
      "description": "Sets table style configuration as JSON string.",
      "parameters": [
        {
          "name": "styleConfig",
          "type": "string",
          "description": "JSON style configuration."
        }
      ],
      "returnType": "void"
    },
    "setCustomCss": {
      "description": "Sets custom CSS string.",
      "parameters": [
        {
          "name": "customCss",
          "type": "string",
          "description": "CSS string."
        }
      ],
      "returnType": "void"
    },
    "setData": {
      "description": "Sets config, columns, styleConfig, customCss and rows at once.",
      "parameters": [
        {
          "name": "data",
          "type": "string",
          "description": "JSON object with config, columns, styleConfig, customCss and rows."
        }
      ],
      "returnType": "void"
    },
    "clear": {
      "description": "Clears appendix table rows.",
      "parameters": [],
      "returnType": "void"
    }
  },
  "events": {}
}